generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      String
  status    String     @default("active")
  createdAt DateTime   @default(now())
  documents Document[]
}

model Patient {
  id                Int               @id @default(autoincrement())
  name              String
  nationalId        String?
  email             String?
  phone             String?
  dateOfBirth       DateTime?
  address           String?
  insuranceProvider String?
  createdAt         DateTime          @default(now())
  deletedAt         DateTime?
  appointments      Appointment[]
  payments          Payment[]
  dentalProcedures  DentalProcedure[]
  documents         Document[]
  consents          Consent[]
  medicalHistory    MedicalHistory?
  cotizaciones      Cotizacion[]

  @@index([deletedAt])
  @@index([name])
}

model Appointment {
  id          Int      @id @default(autoincrement())
  patient     Patient  @relation(fields: [patientId], references: [id])
  patientId   Int
  doctorId    Int?
  procedure   String
  scheduledAt DateTime
  duration    Int
  status      String   @default("scheduled")
  notes       String?
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  @@index([patientId])
  @@index([status])
  @@index([scheduledAt])
  @@index([deletedAt])
}

model Payment {
  id                Int      @id @default(autoincrement())
  patient           Patient  @relation(fields: [patientId], references: [id])
  patientId         Int
  appointmentId     Int?
  procedure         String?
  items             Json?
  originalAmount    Float
  insuranceCoverage Float    @default(0)
  finalAmount       Float
  amountPaid        Float    @default(0)
  status            String   @default("pending")
  paymentMethod     String?
  transactionId     String?
  notes             String?
  createdAt         DateTime @default(now())
  deletedAt         DateTime?
  transactions      PaymentTransaction[]

  @@index([patientId])
  @@index([status])
  @@index([deletedAt])
}

model PaymentTransaction {
  id            Int      @id @default(autoincrement())
  payment       Payment  @relation(fields: [paymentId], references: [id])
  paymentId     Int
  amount        Float
  method        String?
  transactionId String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([paymentId])
}

model DentalProcedure {
  id          Int       @id @default(autoincrement())
  patient     Patient   @relation(fields: [patientId], references: [id])
  patientId   Int
  toothNumber Int
  condition   String
  treatment   String
  status      String    @default("planned")
  doctorId    Int?
  cost        Float?
  date        DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([patientId])
  @@index([status])
  @@index([deletedAt])
}

model Insurance {
  id              Int      @id @default(autoincrement())
  name            String
  code            String?
  contact         String?
  notes           String?
  defaultCoverage Float?   @default(0)
  createdAt       DateTime @default(now())
  plans           InsurancePlan[]
}

model Document {
  id         Int       @id @default(autoincrement())
  patient    Patient?  @relation(fields: [patientId], references: [id])
  patientId  Int?
  uploader   User?     @relation(fields: [uploaderId], references: [id])
  uploaderId Int?
  filename   String
  key        String    @unique
  type       String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  consents   Consent[]

  @@index([patientId])
  @@index([type])
}

model Consent {
  id         Int       @id @default(autoincrement())
  patient    Patient   @relation(fields: [patientId], references: [id])
  patientId  Int
  templateId String?
  formData   Json?
  signerName String?
  signedAt   DateTime?
  document   Document? @relation(fields: [documentId], references: [id])
  documentId Int?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  @@index([patientId])
  @@index([deletedAt])
}

model InsurancePlan {
  id          Int                 @id @default(autoincrement())
  insurance   Insurance           @relation(fields: [insuranceId], references: [id])
  insuranceId Int
  planName    String
  type        String?
  procedures  InsuranceProcedure[]
  createdAt   DateTime            @default(now())

  @@index([insuranceId])
}

model InsuranceProcedure {
  id             Int           @id @default(autoincrement())
  plan           InsurancePlan @relation(fields: [planId], references: [id])
  planId         Int
  name           String
  coverageAmount Float?
  copayPercent   Int?
  createdAt      DateTime      @default(now())

  @@index([planId])
}

model TreatmentCatalog {
  id        Int       @id @default(autoincrement())
  name      String
  price     Float     @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([deletedAt])
}

model MedicalHistory {
  id        Int       @id @default(autoincrement())
  patient   Patient   @relation(fields: [patientId], references: [id])
  patientId Int       @unique

  // Personal antecedents (Si/No answers stored as Json)
  personalAnswers   Json?  // { q1: true, q2: false, ... q15: null }
  // Free text for Q4 (current medications)
  currentMedications String?

  // Dental history (Si/No answers)
  dentalAnswers     Json?  // { d1: true, d2: false, ... d5: null }
  // Last dental visit
  lastDentalVisit   String?

  // Allergy section
  allergyNsaids      String?
  allergyAntibiotics  String?
  allergyAspirin     String?
  allergyOther       String?

  // General notes / additional medications table
  generalNotes      String?
  medications       Json?  // [{ drug: string, objective: string }]


  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())

  @@index([patientId])
}

model ClinicSettings {
  id        Int      @id @default(autoincrement())
  name      String   @default("DentaCare")
  logoUrl   String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Gasto {
  id        Int       @id @default(autoincrement())
  rnc       String?
  proveedor String
  cliente   String?
  nfc       String?
  factura   String?
  fecha     DateTime
  categoria String?
  cantidad  Float
  descuento Float     @default(0)
  itbis     Float     @default(0)
  total     Float
  notas     String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Cotizacion {
  id          Int       @id @default(autoincrement())
  patientId   Int
  patient     Patient   @relation(fields: [patientId], references: [id])
  title       String
  items       Json      // Array of {name, description, quantity, price}
  subtotal    Float
  discount    Float     @default(0)
  tax         Float     @default(0)
  total       Float
  status      String    @default("pending") // pending, approved, partial, paid, cancelled
  validUntil  DateTime?
  notes       String?
  amountPaid  Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([patientId])
}
